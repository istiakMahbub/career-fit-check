GEMINI_API_KEY=your_gemini_key_here
ADZUNA_APP_ID=your_adzuna_app_id
ADZUNA_API_KEY=your_adzuna_api_key
DB_PATH=./career_fit.db
GITHUB_TOKEN=                        # optional — raises GitHub API rate limit from 60 → 5000 req/hr

# ── Local AI — avoids Gemini free-tier limits (recommended) ──────────────────
# Skill extraction runs locally with no quota. Two options:
#
# Option A — LM Studio (GUI, easiest):
#   1. Download LM Studio from https://lmstudio.ai
#   2. Search "Llama-3.2-3B-Instruct", download Q4_K_M from lmstudio-community
#   3. Load the model, go to "Local Server" tab, click Start Server
#   4. Set:  LOCAL_MODEL_NAME=local-model
#            LOCAL_AI_URL=http://localhost:1234
#
# Option B — Ollama (CLI):
#   1. Install from https://ollama.ai
#   2. Run: ollama pull llama3.2:3b
#   3. Set:  LOCAL_MODEL_NAME=llama3.2:3b
#            LOCAL_AI_URL=http://localhost:11434   (default, can omit)
#
LOCAL_MODEL_NAME=                    # set this to enable local AI
LOCAL_AI_URL=http://localhost:11434  # change to :1234 for LM Studio
